{
    "name": "supasalon",
    "devDependencies": {
        "@biomejs/biome": "^1.9.4",
        "turbo": "^2.8.1"
    },
    "overrides": {
        "cookie": ">=1.1.1",
        "esbuild": ">=0.25.0"
    },
    "packageManager": "bun@1.3.9",
    "private": true,
    "scripts": {
        "dev": "bun run dev:web & bun run dev:api",
        "dev:all": "turbo dev --filter=web --filter=mobile & bun run dev:api",
        "dev:web": "turbo dev --filter=web",
        "dev:api": "DOTNET_WATCH_SUPPRESS_LAUNCH_BROWSER=1 dotnet watch --project apps/api run",
        "dev:mobile": "turbo dev --filter=mobile",
        "dev:mobile:android": "turbo dev:android --filter=mobile",
        "dev:mobile:android:offline": "bun --filter=mobile run dev:android:offline",
        "dev:mobile:ios": "turbo dev:ios --filter=mobile",
        "android:emulator": "powershell -NoProfile -Command \"& \\\"$env:ANDROID_HOME\\\\emulator\\\\emulator\\\" -avd Medium_Phone_API_36.1\"",
        "build": "turbo build",
        "build:web": "turbo build --filter=web",
        "lint": "biome lint .",
        "lint:fix": "biome lint --write .",
        "format": "biome format --write .",
        "format:check": "biome format .",
        "db:generate": "sh -c 'dotnet ef migrations add \"$1\" --project apps/api --startup-project apps/api --output-dir Migrations' --",
        "db:migrate:local": "dotnet ef database update --project apps/api --startup-project apps/api",
        "db:studio": "dotnet ef migrations list --project apps/api --startup-project apps/api"
    },
    "workspaces": [
        "apps/*",
        "packages/*"
    ]
}
